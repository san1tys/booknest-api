msgid "User"
msgstr "Пайдаланушы"

#: apps/bookings/models.py:27
msgid "The user who made the booking."
msgstr "Бронь жасаған пайдаланушы."

#: apps/bookings/models.py:33 apps/rooms/models.py:44
msgid "Room"
msgstr "Бөлме"

#: apps/bookings/models.py:34
msgid "The room that is booked."
msgstr "Бронь жасалған бөлме."

#: apps/bookings/models.py:37
msgid "Check-in Date"
msgstr "Кіру күні"

#: apps/bookings/models.py:38
msgid "The date when the booking starts."
msgstr "Бронь басталатын күн."

#: apps/bookings/models.py:41
msgid "Check-out Date"
msgstr "Шығу күні"

#: apps/bookings/models.py:42
msgid "The date when the booking ends."
msgstr "Бронь аяқталатын күн."

#: apps/bookings/models.py:48
msgid "Booking Status"
msgstr "Бронь күйі"

#: apps/bookings/models.py:50
msgid ""
"The current status of the booking (e.g., pending, confirmed, cancelled)."
msgstr "Броньның ағымдағы күйі (мысалы, күтуде, расталды, бас тартылды)."

#: apps/bookings/models.py:57
msgid "Total Price"
msgstr "Жалпы баға"

#: apps/bookings/models.py:58
msgid "The total price for the booking."
msgstr "Броньның жалпы бағасы."

#: apps/bookings/models.py:64
msgid "Booking"
msgstr "Бронь"

#: apps/bookings/models.py:65
msgid "Bookings"
msgstr "Броньдар"

#: apps/bookings/models.py:69 apps/bookings/serializers.py:28
#: apps/bookings/serializers.py:99
msgid "Check-out date must be after check-in date."
msgstr "Шығу күні кіру күнінен кейін болуы керек."

#: apps/bookings/views.py:268
msgid "Booking not found."
msgstr "Бронь табылмады."

#: apps/bookings/views.py:276
msgid "You do not have permission to cancel this booking."
msgstr "Сізде бұл броньды жоюға рұқсат жоқ."

#: apps/bookings/views.py:282
msgid "This booking is already cancelled."
msgstr "Бұл бронь әлдеқашан жойылған."

#: apps/hotels/models.py:39
msgid "A hotel with this name already exists. Please choose a different name."
msgstr "Мұндай атаумен қонақүй бұрыннан бар. Басқа атау таңдаңыз."

#: apps/hotels/models.py:43
msgid "Hotel Name"
msgstr "Қонақүй атауы"

#: apps/hotels/models.py:44
msgid "Enter the name of the hotel."
msgstr "Қонақүйдің атауын енгізіңіз."

#: apps/hotels/models.py:50
msgid "Hotel Address"
msgstr "Қонақүй мекенжайы"

#: apps/hotels/models.py:51
msgid "Enter the address of the hotel."
msgstr "Қонақүйдің мекенжайын енгізіңіз."

#: apps/hotels/models.py:57
msgid "Hotel City"
msgstr "Қонақүй қаласы"

