msgid "Authentication credentials were not provided."
msgstr "Аутентификация деректері ұсынылмады."

#: apps/reviews/views.py:132
msgid "You can review this hotel only after a confirmed/completed booking."
msgstr "Сіз бұл қонақүйге тек расталған немесе аяқталған броньдан кейін ғана пікір қалдыра аласыз."

#: apps/reviews/views.py:139
msgid "You already reviewed this hotel."
msgstr "Сіз бұл қонақүйге пікір қалдырып қойғансыз."

#: apps/rooms/models.py:18
msgid "Parent hotel."
msgstr "Негізгі қонақүй."

#: apps/rooms/models.py:22
msgid "Room title"
msgstr "Бөлме атауы"

#: apps/rooms/models.py:23
msgid "e.g. \"Deluxe Room\""
msgstr "мысалы, \"Deluxe Room\""

#: apps/rooms/models.py:28
msgid "Price per night"
msgstr "Бір түннің бағасы"

#: apps/rooms/models.py:29
msgid "Decimal price per night."
msgstr "Бір түннің ондық форматтағы бағасы."

#: apps/rooms/models.py:32
msgid "Capacity"
msgstr "Сыйымдылық"

#: apps/rooms/models.py:33
msgid "Guests count this room type can host."
msgstr "Бұл бөлме түрі қабылдай алатын қонақтар саны."

