#: apps/rooms/models.py:45
msgid "Rooms"
msgstr "Бөлмелер"

#: apps/rooms/models.py:49
msgid "Price per night must be positive."
msgstr "Бір түннің бағасы оң сан болуы керек."

#: apps/rooms/models.py:51
msgid "Capacity must be greater than 0."
msgstr "Сыйымдылық 0-ден үлкен болуы керек."

#: apps/rooms/models.py:53
msgid "Quantity must be greater than 0."
msgstr "Саны 0-ден үлкен болуы керек."

#: apps/rooms/serializers.py:24
msgid "Must be positive."
msgstr "Оң сан болуы керек."

#: apps/rooms/serializers.py:26 apps/rooms/serializers.py:28
msgid "Must be greater than 0."
msgstr "0-ден үлкен болуы керек."

#: apps/rooms/views.py:87
msgid "Only the hotel owner can create rooms."
msgstr "Бөлмелерді тек қонақүй иесі ғана жасай алады."

#: apps/rooms/views.py:141
msgid "Room not found."
msgstr "Бөлме табылмады."

#: apps/rooms/views.py:145
msgid "You do not have permission to edit this room."
msgstr "Сізде бұл бөлмені өңдеуге рұқсат жоқ."

#: apps/rooms/views.py:207 apps/rooms/views.py:327 apps/rooms/views.py:340
msgid "Room deleted successfully."
msgstr "Бөлме сәтті жойылды."

