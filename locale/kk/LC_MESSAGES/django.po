msgid "Hotel Rating"
msgstr "Қонақүй рейтингі"

#: apps/hotels/models.py:64
msgid "Enter the rating of the hotel (1-5)."
msgstr "Қонақүй рейтингін енгізіңіз (1-5)."

#: apps/hotels/models.py:69
msgid "Hotel Description"
msgstr "Қонақүй сипаттамасы"

#: apps/hotels/models.py:70
msgid "Enter a description of the hotel."
msgstr "Қонақүйдің сипаттамасын енгізіңіз."

#: apps/hotels/models.py:79
msgid "Hotel Owner"
msgstr "Қонақүй иесі"

