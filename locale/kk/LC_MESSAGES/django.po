msgid "Hotel"
msgstr "Қонақүй"

#: apps/hotels/models.py:87
msgid "Hotels"
msgstr "Қонақүйлер"

#: apps/hotels/models.py:92
msgid "Rating must be between 1 and 5."
msgstr "Рейтинг 1 мен 5 аралығында болуы керек."

#: apps/hotels/views.py:142 apps/hotels/views.py:218 apps/hotels/views.py:308
msgid "Hotel not found."
msgstr "Қонақүй табылмады."

#: apps/hotels/views.py:147
msgid "You do not have permission to edit this hotel."
msgstr "Сізде бұл қонақүйді өңдеуге рұқсат жоқ."

#: apps/hotels/views.py:313
msgid "You do not have permission to delete this hotel."
msgstr "Сізде бұл қонақүйді жоюға рұқсат жоқ."

#: apps/hotels/views.py:322
msgid "Hotel deleted successfully."
msgstr "Қонақүй сәтті жойылды."

#: apps/reviews/models.py:23
msgid "Rating"
msgstr "Рейтинг"

