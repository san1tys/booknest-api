msgstr "Растау коды жарамсыз немесе мерзімі өтіп кеткен."

#: apps/users/views.py:209
msgid "Email verified successfully."
msgstr "Email сәтті расталды."

#: apps/users/views.py:256
msgid "A new verification OTP was sent to your email."
msgstr "Email-іңізге жаңа растау OTP жіберілді."

#: apps/users/views.py:314
msgid "Invalid email or password."
msgstr "Email немесе құпиясөз қате."

#: apps/users/views.py:319
msgid "User account is disabled."
msgstr "Пайдаланушы аккаунты өшірілген."

#: apps/users/views.py:324
msgid "Email is not verified."
msgstr "Email расталмаған."

